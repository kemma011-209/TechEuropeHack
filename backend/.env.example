# Example environment variables for the backend.
# Copy this file to .env and fill in real values. Do NOT commit .env.

# Google Generative Language API key (used by the critic swarm).
GEMMA_API_KEY=
# Model proven to work against the key above (see quicktest.py).
GEMMA_MODEL=gemini-3.5-flash

# Superlinked Inference Engine (used by draft + shorten via POST /v1/generate).
# Leave SUPERLINKED_BASE_URL blank to use demo data. Text generation requires a
# SIE instance running the SGLang/GPU image with a "Generators" model loaded
# (e.g. http://localhost:8080 locally, or your hosted SIE gateway URL).
SUPERLINKED_API_KEY=
SUPERLINKED_BASE_URL=
SUPERLINKED_MODEL=Qwen/Qwen3-4B-Instruct-2507

# Tavily Search API key (used by tavily_test.py for live web search).
# Get one at https://app.tavily.com — keys are prefixed with "tvly-".
TAVILY_API_KEY=

# Comma-separated origins allowed to call the API (the Next.js dev server).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
